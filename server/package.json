    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.0.1",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
